<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="20260528-02-verein-countrycode" author="chatgpt">

        <!-- Neue Spalte hinzufügen -->
        <addColumn tableName="verein">
            <column name="country_code" type="char(2)" defaultValue="DE"/>
        </addColumn>

        <!-- Bestehende Datensätze absichern -->
        <update tableName="verein">
            <column name="country_code" value="DE"/>
            <where>country_code IS NULL</where>
        </update>

        <!-- NOT NULL setzen -->
        <addNotNullConstraint
                tableName="verein"
                columnName="country_code"
                columnDataType="char(2)"/>

    </changeSet>

</databaseChangeLog>