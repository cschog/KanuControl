<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="2026-03-03-planung-on-delete-cascade" author="chris">

    <!-- 1️⃣ Bestehende FK entfernen (falls sie existiert) -->
    <dropForeignKeyConstraint
            baseTableName="planung"
            constraintName="fk_planung_veranstaltung"/>

    <!-- 2️⃣ Neue FK mit ON DELETE CASCADE -->
    <addForeignKeyConstraint
            baseTableName="planung"
            baseColumnNames="veranstaltung_id"
            constraintName="fk_planung_veranstaltung"
            referencedTableName="veranstaltung"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

    <rollback>
        <dropForeignKeyConstraint
                baseTableName="planung"
                constraintName="fk_planung_veranstaltung"/>

        <addForeignKeyConstraint
                baseTableName="planung"
                baseColumnNames="veranstaltung_id"
                constraintName="fk_planung_veranstaltung"
                referencedTableName="veranstaltung"
                referencedColumnNames="id"/>
    </rollback>

    </changeSet>
</databaseChangeLog>