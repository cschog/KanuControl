<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="2026-03-19-01-add-lfdnr-to-beleg" author="chris">

        <addColumn tableName="abrechnung_beleg">
            <column name="lfd_nr" type="INT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addUniqueConstraint
                tableName="abrechnung_beleg"
                columnNames="abrechnung_id, beleg_nummer"
                constraintName="uk_beleg_abrechnung_nummer"/>

    </changeSet>

</databaseChangeLog>