<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="20260626-03-veranstaltung-fk" author="chris">

        <addColumn tableName="veranstaltung">

            <column name="unterkunftsart_id" type="BIGINT"/>

            <column name="verpflegungsmodell_id" type="BIGINT"/>

        </addColumn>

        <addForeignKeyConstraint
                baseTableName="veranstaltung"
                baseColumnNames="unterkunftsart_id"
                referencedTableName="unterkunftsart"
                referencedColumnNames="id"
                constraintName="fk_veranstaltung_unterkunft"/>

        <addForeignKeyConstraint
                baseTableName="veranstaltung"
                baseColumnNames="verpflegungsmodell_id"
                referencedTableName="verpflegungsmodell"
                referencedColumnNames="id"
                constraintName="fk_veranstaltung_verpflegung"/>

    </changeSet>

</databaseChangeLog>