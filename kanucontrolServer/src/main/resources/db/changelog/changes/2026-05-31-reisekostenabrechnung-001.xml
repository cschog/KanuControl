<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="reisekostenabrechnung-001" author="chris">

        <createTable tableName="reisekostenabrechnung">

            <column name="id" type="BIGSERIAL">
                <constraints
                        primaryKey="true"
                        nullable="false"/>
            </column>

            <column name="veranstaltung_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="fahrer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="abrechnungsdatum" type="DATE"/>

            <column name="gesamt_kilometer" type="INTEGER"/>

            <column name="gesamt_betrag" type="NUMERIC(10,2)"/>

            <column name="bemerkung" type="VARCHAR(1000)"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="reisekostenabrechnung"
                baseColumnNames="veranstaltung_id"
                referencedTableName="veranstaltung"
                referencedColumnNames="id"
                constraintName="fk_rk_veranstaltung"/>

        <addForeignKeyConstraint
                baseTableName="reisekostenabrechnung"
                baseColumnNames="fahrer_id"
                referencedTableName="person"
                referencedColumnNames="id"
                constraintName="fk_rk_fahrer"/>

        <createIndex
                tableName="reisekostenabrechnung"
                indexName="idx_rk_veranstaltung">
            <column name="veranstaltung_id"/>
        </createIndex>

        <createIndex
                tableName="reisekostenabrechnung"
                indexName="idx_rk_fahrer">
            <column name="fahrer_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>