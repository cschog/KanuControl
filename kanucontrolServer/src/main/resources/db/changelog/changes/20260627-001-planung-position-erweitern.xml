<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="20260627-001-planung-position-erweitern" author="chris">

        <addColumn tableName="planung_position">

            <column name="menge"
                    type="numeric(12,2)"/>

            <column name="einheit"
                    type="varchar(50)"/>

            <column name="einzelpreis"
                    type="numeric(12,2)"/>

            <column name="automatisch_berechnet"
                    type="boolean"
                    defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="editierbar"
                    type="boolean"
                    defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

        </addColumn>

    </changeSet>

</databaseChangeLog>