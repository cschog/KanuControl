<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="2026-02-27-foerdersatz-create" author="chris">

        <createTable tableName="foerdersatz">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="gueltig_von" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="gueltig_bis" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="betrag_pro_teilnehmer" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="beschluss" type="VARCHAR(255)"/>
        </createTable>

        <createIndex indexName="idx_foerdersatz_zeitraum"
                     tableName="foerdersatz">
            <column name="gueltig_von"/>
            <column name="gueltig_bis"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>