<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">
    <changeSet id="2026-05-04-02-create-beitragsregel" author="chris">

        <createTable tableName="beitragsregel">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="beitragsstruktur_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="alter_von" type="INT"/>

            <column name="alter_bis" type="INT"/>

            <column name="rolle" type="CHAR(1)"/>

            <column name="beitrag" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- FK -->
        <addForeignKeyConstraint
                baseTableName="beitragsregel"
                baseColumnNames="beitragsstruktur_id"
                referencedTableName="beitragsstruktur"
                referencedColumnNames="id"
                constraintName="fk_beitragsregel_struktur"/>

    </changeSet>

</databaseChangeLog>