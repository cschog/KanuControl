<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="global-005-create-kik-zuschlag" author="chris">

    <createTable schemaName="public"
                 tableName="kik_zuschlag">

        <column name="id"
                type="BIGINT"
                autoIncrement="true">

            <constraints primaryKey="true"
                         primaryKeyName="kik_zuschlag_pkey"
                         nullable="false"/>
        </column>

        <column name="gueltig_von"
                type="DATE">

            <constraints nullable="false"/>
        </column>

        <column name="gueltig_bis"
                type="DATE"/>

        <column name="kik_zuschlag"
                type="NUMERIC(10,2)">

            <constraints nullable="false"/>
        </column>

        <column name="beschluss"
                type="VARCHAR(255)"/>

    </createTable>

    <sql dbms="postgresql"><![CDATA[
    ALTER TABLE public.kik_zuschlag
    ADD CONSTRAINT kik_zuschlag_no_overlap
    EXCLUDE USING gist (
        daterange(
            gueltig_von,
            gueltig_bis,
            '[]'
        ) WITH &&
    );
]]></sql>

    </changeSet>


</databaseChangeLog>