<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">


<changeSet id="global-002-create-foerdersatz" author="chris">

    <createTable schemaName="public"
                 tableName="foerdersatz">

        <column name="id"
                type="BIGINT"
                autoIncrement="true">

            <constraints primaryKey="true"
                         primaryKeyName="foerdersatz_pkey"
                         nullable="false"/>
        </column>

        <column name="gueltig_von"
                type="DATE">

            <constraints nullable="false"/>
        </column>

        <column name="gueltig_bis"
                type="DATE"/>

        <column name="foerdersatz"
                type="NUMERIC(10,2)">

            <constraints nullable="false"/>
        </column>

        <column name="beschluss"
                type="VARCHAR(255)"/>

        <column name="typ"
                type="VARCHAR(20)">

            <constraints nullable="false"/>
        </column>

    </createTable>

    <addUniqueConstraint
            schemaName="public"
            tableName="foerdersatz"
            columnNames="typ,gueltig_von"
            constraintName="uk_foerdersatz_typ_gueltigkeit"/>

    <createIndex
            schemaName="public"
            tableName="foerdersatz"
            indexName="idx_foerdersatz_zeitraum">

        <column name="gueltig_von"/>
        <column name="gueltig_bis"/>

    </createIndex>

    <sql dbms="postgresql"><![CDATA[
    ALTER TABLE public.foerdersatz
    ADD CONSTRAINT foerdersatz_typ_no_overlap
    EXCLUDE USING gist (
        typ WITH =,
        daterange(
            gueltig_von,
            gueltig_bis,
            '[]'
        ) WITH &&
    );
]]></sql>

</changeSet>

</databaseChangeLog>